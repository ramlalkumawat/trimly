# === CORE CONFIGURATION ===
NODE_ENV=development
PORT=5000

# === DATABASE ===
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/trimly?retryWrites=true&w=majority

# === AUTHENTICATION & SECURITY ===
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
ADMIN_REGISTRATION_KEY=your-admin-registration-key

# === SESSION & COOKIES ===
SESSION_SECRET=your-session-secret-key-change-in-production
COOKIE_SECRET=your-cookie-secret-key-change-in-production

# === PASSWORD RESET EMAIL CONFIGURATION ===
# Email Provider: 'smtp' (default), 'gmail', 'sendgrid', 'aws-ses'
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@trimly.com
APP_URL=http://localhost:3000

# SMTP Configuration (for most providers)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_SECURE=false

# Gmail Configuration (if using Gmail)
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-app-specific-password

# SendGrid Configuration (if using SendGrid)
# SENDGRID_API_KEY=your-sendgrid-api-key

# AWS SES Configuration (if using AWS SES)
# AWS_REGION=us-east-1
# AWS_SES_USER=your-aws-ses-user
# AWS_SES_PASSWORD=your-aws-ses-password

# === CORS & FRONTEND URLS ===
# Frontend URLs for Socket.io CORS (comma-separated in production/Render)
# Example (Render static sites):
# CLIENT_URLS=https://trimly-user.onrender.com,https://trimly-provider.onrender.com,https://trimly-admin.onrender.com
CLIENT_URL=http://localhost:3000
CLIENT_URLS=http://localhost:3000,http://localhost:5173

# === SECURITY HEADERS ===
# Content Security Policy Report URI (optional)
# CSP_REPORT_URI=https://your-csp-collector.example.com/report
CSP_REPORT_ONLY=false

# === AUDIT LOGGING ===
# Optional external audit log collection service
# AUDIT_LOG_URL=https://your-audit-service.example.com/logs

# === PASSWORD REQUIREMENTS ===
# Bcrypt salt rounds (8-14, default 10)
BCRYPT_SALT_ROUNDS=10

# === RATE LIMITING ===
# All rate limiters are configured in middleware, these are just reference values
# Auth limiter: 5 attempts per 15 minutes
# Password reset limiter: 3 attempts per hour
# General API limiter: 100 requests per minute
# Strict limiter: 10 requests per hour for sensitive operations

